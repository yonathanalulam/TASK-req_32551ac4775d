# Meridian local configuration. Copy to .env and edit as needed.
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_PORT=8080

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=meridian
DB_USERNAME=meridian
DB_PASSWORD=meridian_pass
DB_ROOT_PASSWORD=meridian_root

# AES-256 master key. Generate with: php -r "echo bin2hex(random_bytes(32));"
# Must be 64 hex chars. This file is the ONLY place this secret lives at rest on host.
APP_MASTER_KEY=replace_with_64_hex_chars_from_random_bytes_32_output_here_0000000
APP_MASTER_KEY_VERSION=1

# Default operator and admin bootstrap parameters
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMePlease!42

# Session policy (seconds)
SESSION_ABSOLUTE_TTL=43200
SESSION_IDLE_TTL=7200
SESSION_MAX_CONCURRENT=5

# Rate limit default (requests/min/user)
RATE_LIMIT_DEFAULT=60

# Local export root directory (must be inside storage/)
EXPORT_ROOT=storage/exports
REPORT_ROOT=storage/reports
