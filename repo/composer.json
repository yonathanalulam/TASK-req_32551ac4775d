{
    "name": "meridian/platform",
    "description": "Meridian Content Integrity & Event Ops Platform - offline single-host backend",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0",
        "vlucas/phpdotenv": "^5.5",
        "ramsey/uuid": "^4.7",
        "monolog/monolog": "^3.4",
        "symfony/console": "^6.3",
        "robmorgan/phinx": "^0.16.0",
        "ext-pdo": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-dom": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Meridian\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Meridian\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "migrate": "vendor/bin/phinx migrate -c phinx.php",
        "seed": "vendor/bin/phinx seed:run -c phinx.php",
        "test": "vendor/bin/phinx migrate -e testing -c phinx.php && vendor/bin/phpunit",
        "jobs:daily": "php scripts/run_daily_jobs.php",
        "audit:verify": "php scripts/verify_audit_chain.php",
        "admin:bootstrap": "php scripts/bootstrap_admin.php",
        "demo:bootstrap": "php scripts/bootstrap_demo_users.php",
        "key:rotate": "php scripts/rotate_key.php"
    }
}
